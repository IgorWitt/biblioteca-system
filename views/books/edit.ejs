<%- include('../partials/header') %>

<h1>Editar Livro</h1>

<% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<form method="POST" action="/books/<%= book.id %>" class="form">
  <div class="form-group">
    <label for="title">Titulo</label>
    <input type="text" id="title" name="title" value="<%= book.title %>" required>
  </div>
  <div class="form-group">
    <label for="author">Autor</label>
    <input type="text" id="author" name="author" value="<%= book.author %>" required>
  </div>
  <div class="form-group">
    <label for="isbn">ISBN</label>
    <input type="text" id="isbn" name="isbn" value="<%= book.isbn %>" required>
  </div>
  <div class="form-group">
    <label for="quantity">Quantidade Total</label>
    <input type="number" id="quantity" name="quantity" min="1" value="<%= book.quantity %>" required>
  </div>
  <div class="form-group">
    <label for="available">Disponiveis</label>
    <input type="number" id="available" name="available" min="0" value="<%= book.available %>" required>
  </div>
  <button type="submit" class="btn btn-primary">Salvar</button>
  <a href="/books" class="btn">Cancelar</a>
</form>

<%- include('../partials/footer') %>
